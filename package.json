{
  "name": "ummense-dr",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/backend",
    "packages/frontend"
  ],
  "scripts": {
    "dev": "npm run dev:split",
    "dev:split": "node -e \"console.log('Split-run strategy: run npm run dev:backend and npm run dev:frontend in separate terminals.')\"",
    "dev:backend": "npm run env:check:backend && npm run dev --workspace @ummense/backend",
    "dev:frontend": "npm run env:check:frontend && npm run dev --workspace @ummense/frontend",
    "infra:up": "bash ./scripts/local-infra.sh up",
    "infra:down": "bash ./scripts/local-infra.sh down",
    "infra:reset": "bash ./scripts/local-infra.sh reset",
    "infra:seed": "bash ./scripts/local-infra.sh seed",
    "infra:status": "bash ./scripts/local-infra.sh status",
    "infra:check:redis": "node ./scripts/check-redis-connectivity.mjs",
    "env:check": "node ./scripts/env-check.mjs --target all",
    "env:check:backend": "node ./scripts/env-check.mjs --target backend",
    "env:check:frontend": "node ./scripts/env-check.mjs --target frontend",
    "env:check:infra": "node ./scripts/env-check.mjs --target infra",
    "quality:gates": "node ./scripts/quality-gates.mjs",
    "quality:gates:red": "GATE_FORCE_FAIL_STAGE=test node ./scripts/quality-gates.mjs",
    "qa:epic6:fixture": "node ./scripts/create-epic6-parity-fixture.mjs",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm run test --workspaces",
    "test:wave2:harness": "npm run test:wave2-harness --workspace @ummense/backend",
    "test:wave3:websocket": "npm run test:websocket --workspace @ummense/backend",
    "test:wave3:saved-filters": "npm run test:saved-filters --workspace @ummense/backend",
    "benchmark:wave3:websocket": "npm run benchmark:websocket --workspace @ummense/backend",
    "benchmark:wave3:websocket:smoke": "npm run benchmark:websocket:smoke --workspace @ummense/backend",
    "test:e2e:parity": "playwright test -c packages/e2e/playwright.parity.config.ts",
    "typecheck:backend:full": "npm run typecheck:full --workspace @ummense/backend",
    "test:wave2:integrations": "npx vitest run -c vitest.wave2-integrations.config.ts"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "eslint": "^9.23.0",
    "@typescript-eslint/parser": "^8.30.0"
  }
}
