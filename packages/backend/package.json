{
  "name": "@ummense/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc --project tsconfig.quality.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"api/**/*.ts\"",
    "typecheck": "tsc --project tsconfig.quality.json --noEmit",
    "test": "tsx --test src/__tests__/auth.service.security.test.ts",
    "test:cost-monitoring": "vitest run src/__tests__/cost-snapshot.service.test.ts src/__tests__/analytics-cost-summary.test.ts src/__tests__/nightly-cost-snapshot.test.ts",
    "test:saved-filters": "vitest run src/__tests__/saved-filters.test.ts",
    "test:websocket": "vitest run src/__tests__/websocket-unit.test.ts",
    "benchmark:websocket": "tsx src/scripts/websocket-load-benchmark.ts",
    "benchmark:websocket:smoke": "WS_BENCHMARK_DURATION_SECONDS=30 WS_BENCHMARK_WARMUP_SECONDS=2 WS_BENCHMARK_CLIENTS=20 WS_BENCHMARK_SAMPLE_INTERVAL_MS=1000 tsx src/scripts/websocket-load-benchmark.ts",
    "test:wave2-harness": "vitest run tests/event-system.test.ts tests/rule-engine.test.ts tests/webhook-delivery.test.ts",
    "typecheck:full": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1002.0",
    "@supabase/supabase-js": "^2.57.4",
    "aws-sdk": "^2.1692.0",
    "bcrypt": "^6.0.0",
    "bull": "^4.16.5",
    "cors": "^2.8.5",
    "cron": "^4.3.2",
    "cron-parser": "^5.4.0",
    "express": "^5.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.2",
    "node-schedule": "^2.1.1",
    "rate-limiter-flexible": "^9.1.1",
    "redis": "^5.8.2",
    "socket.io": "^4.8.1",
    "uuid": "^13.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bull": "^3.15.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/ioredis": "^4.28.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.3.0",
    "@types/node-schedule": "^2.1.8",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  }
}
